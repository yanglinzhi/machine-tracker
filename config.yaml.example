# MachineTracker (mt) 配置文件示例
# ---------------------------------------------------------
# 说明：此文件为配置模板。初始化后，你的私有配置位于：
# ~/.config/machine-tracker/config.yaml

# 1. 机器定义 (Machines)
# 目前版本专注于本地审计，通常保留 'local' 即可。
machines:
  local:
    id: "local-server"            # 机器唯一标识
    name: "生产环境-01"            # 在 Web 界面显示的友好名称
    scan_interval: "10m"          # 后台自动扫描间隔 (由 mt cron 管理)

# 2. 存储管理 (Storage)
storage:
  path: "~/.local/share/machine-tracker"  # 快照数据库存放路径
  keep_snapshots: 50                       # 自动清理：保留最近 50 份快照
  compress_old: true                       # 开启 Gzip 压缩 (空间占用降低 85%)

# 3. 采集器定义 (Collectors)
collectors:
  # 启用的维度。若不需要某项，直接将其从列表中删除即可。
  enabled: 
    - service_mapper    # 【核心】端口与服务溯源
    - apt               # APT 软件包监控
    - docker            # Docker 容器审计
    - systemd           # 系统服务单元追踪
    - network           # 端口监听扫描
    - nginx             # Nginx 反向代理画像
    - cron              # 定时任务监控
    - filesystem        # 磁盘分区与挂载点
    - npm               # Node.js 全局包
    - pip               # Python 软件包
    - config_files      # 关键配置文件 Hash 校验

  # 针对特定采集器的参数
  config_files:
    watch_paths:        # 你最关心的配置文件或目录
      - "/etc/nginx/"
      - "/etc/fstab"
      - "/etc/shadow"
      - "/etc/sudoers"
      - "~/.bashrc"

# 4. 风险评估引擎 (Risk Assessment)
# 当变更项匹配以下正则表达式时，报告中将标记红色警告 (🔴 HIGH RISK)
risk_rules:
  - pattern: "sshd_config|/etc/ssh"
    level: "HIGH"
    reason: "SSH 关键配置变动，可能影响系统远程访问安全性。"
  - pattern: "sudoers|/etc/sudo|/etc/shadow"
    level: "HIGH"
    reason: "检测到权限提升或账号敏感文件变更，请务必核实。"
  - pattern: "passwd|shadow|group"
    level: "HIGH"
    reason: "系统账号或密码数据库发生变动。"
  - pattern: "crontab|/etc/cron"
    level: "MEDIUM"
    reason: "定时任务变动，请检查是否存在异常的后台计划。"

# 5. 输出选项 (Output)
output:
  format: "markdown"
  changelog_path: "~/.local/share/machine-tracker/changelog.md"
